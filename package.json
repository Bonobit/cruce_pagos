{
  "name": "reconciliation-app",
  "version": "1.0.0",
  "description": "App de conciliación Gestor vs TNS",
  "main": "dist/server.js",
  "bin": "dist/server.js",
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/pdf-parse/**/*"
    ]
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "build:bundle": "esbuild src/server.ts --bundle --platform=node --target=node18 --outfile=dist/bundle.js --external:pino-pretty --alias:@napi-rs/canvas=./src/utils/canvas-mock.ts",
    "build:sea-blob": "node --experimental-sea-config sea-config.json",
    "build:exe": "npm run build:bundle && npm run build:sea-blob && powershell -Command \"Stop-Process -Name Cruce_pagos -ErrorAction SilentlyContinue; if (Test-Path bin/Cruce_pagos.exe) { Remove-Item bin/Cruce_pagos.exe -Force }; Copy-Item (Get-Command node).Source bin/Cruce_pagos.exe -Force\" && postject bin/Cruce_pagos.exe NODE_SEA_BLOB dist/prep.blob --overwrite --sentinel-fuse NODE_SEA_FUSE_fce680ab2cc467b6e072b8b5df1996b2",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@types/pdf-parse": "^1.1.5",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "kill-port": "^2.0.1",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/kill-port": "^2.0.3",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/pino": "^7.0.4",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "esbuild": "^0.27.7",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "pkg": "^5.8.1",
    "postject": "^1.0.0-alpha.6",
    "prettier": "^3.8.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
