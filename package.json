{
  "name": "reconciliation-app",
  "version": "1.0.0",
  "description": "App de conciliación Gestor vs TNS",
  "main": "dist/server.js",
  "bin": "dist/server.js",
  "pkg": {
    "assets": [
      "public/**/*"
    ]
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "build:exe": "npm run build && pkg . --target node18-win-x64 --out-path bin",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@types/open": "^6.1.0",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "kill-port": "^2.0.1",
    "multer": "^1.4.5-lts.1",
    "open": "^11.0.0",
    "pino": "^10.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/kill-port": "^2.0.3",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/pino": "^7.0.4",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "pkg": "^5.8.1",
    "prettier": "^3.8.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
